{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/components/*": [
        "expo/components/*"
      ],
      "@/hooks/*": [
        "expo/hooks/*"
      ],
      "@/theme": [
        "expo/theme/index"
      ],
      "@/theme/*": [
        "expo/theme/*"
      ],
      "@/agent/*": [
        "lib/agent/*"
      ],
      "@/shared/*": [
        "shared/*"
      ]
    }
  },
  "include": [
    "expo/**/*",
    "api/**/*",
    "lib/**/*",
    "shared/**/*",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
