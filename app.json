{
  "expo": {
    "name": "FlixScout",
    "slug": "flixscout",
    "scheme": "flixscout",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#09090F",
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "expo/app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
